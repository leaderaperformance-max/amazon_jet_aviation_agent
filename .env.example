# ---------------------------------------------------------------------------
# Amazon Jet Aviation Agent — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your real values.
# NEVER commit `.env.local` — it is git-ignored.
#
# After deploying to Vercel, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ---------------------------------------------------------------------------

# Supabase project URL (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key (public — safe, RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side URL (same value as NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase service-role key (SECRET — full DB access, bypasses RLS)
# Used by the webhook endpoint and admin auth routes. Never expose client-side.
SUPABASE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# OPENAI and CHATWOOT credentials are stored in the database (per-inbox),
# configurable via /dashboard/settings/openai and /dashboard/inboxes/<id>.
# They are NOT environment variables anymore.
# ---------------------------------------------------------------------------
